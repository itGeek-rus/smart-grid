APP_NAME=smart-grid-processor
APP_ENV=local
APP_LOG_LEVEL=info
HTTP_ADDR=:8080
SHUTDOWN_TIMEOUT=10s

# PostgreSQL / TimescaleDB
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=smart-grid
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=smart-grid-processor
KAFKA_TOPIC_RAW_TELEMETRY=raw.telemetry
KAFKA_TOPIC_PROCESSED_EVENTS=processed.events
KAFKA_TOPIC_ALERTS=alerts
KAFKA_TOPIC_DLQ=raw.telemetry.dlq
KAFKA_CONSUMER_GROUP=processor

# MQTT
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=smart-grid-ingestion
MQTT_TOPIC_TELEMETRY=smartmeter/+/+
MQTT_QOS=1